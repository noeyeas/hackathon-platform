# Supabase 프로젝트 설정 (supabase.com 대시보드 > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 서버 전용 (Service Role) — QR 토큰 발급 등 운영진 작업에 사용. 절대 클라이언트 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 사이트 기본 URL (QR 링크 생성용). 로컬은 http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
